# URL Express API (для SSR і проксі /api/backend/*)
# Локально:
BACKEND_URL=http://localhost:3000

# У Docker Compose сервіс називається `server`:
# BACKEND_URL=http://server:3000

# PostHog (лаб. 5): ключ з PostHog → Project settings
NEXT_PUBLIC_POSTHOG_KEY=
# Прямий ingest (якщо без проксі):
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# First-party проксі через rewrites у next.config.mjs (обхід adblock):
NEXT_PUBLIC_POSTHOG_API_HOST=/ingest
# Панель PostHog EU (toolbar / session replay UI):
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
